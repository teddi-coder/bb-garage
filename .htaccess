RewriteEngine On

# 1. Redirect /page.html → /page (drop the extension)
RewriteCond %{THE_REQUEST} ^[A-Z]+\s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. WordPress slug → new clean URL (301 permanent)
RewriteRule ^next-gen-ranger-amarok-v6-dyno-tune/?$ /next-gen-ranger-v6 [R=301,L,NC]
RewriteRule ^patrol-3-0-cr-power-pack/?$            /patrol-power-pack   [R=301,L,NC]
RewriteRule ^triton-ps-stage-2/?$                   /triton-power-pack   [R=301,L,NC]
RewriteRule ^dyno-tuning-ipswich/?$                 /dyno-tuning         [R=301,L,NC]

# 3. Remove trailing slash on clean URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# 4. Serve .html file for extensionless requests
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
